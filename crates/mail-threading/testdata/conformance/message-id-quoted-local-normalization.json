    "behavior": "Message IDs are normalized so quoted and unquoted forms do not false-mismatch"
  },
  "input": [
    {
      "id": "quoted-root",
      "message_id": "<\"01KF8JCEOCBS0045PS\"@xxx.yyy.com>",
