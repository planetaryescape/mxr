{
  "name": "references-chain-preserves-existing-parent",
  "description": "Adjacent References links do not replace an existing parent on an intermediate message.",
  "spec": {
    "source": "RFC 5256",
    "url": "https://www.rfc-editor.org/rfc/rfc5256",
    "behavior": "when linking adjacent Message IDs in References, an existing parent link is not changed because References may be truncated"
  },
  "input": [
    {
      "id": "preserve-root",
      "message_id": "<preserve-root@example>",
      "in_reply_to": null,
      "references": [],
      "subject": "Preserve parent",
      "date": "2026-05-15T09:00:00Z"
    },
    {
      "id": "preserve-child",
      "message_id": "<preserve-child@example>",
      "in_reply_to": null,
      "references": [
        "<preserve-root@example>"
      ],
      "subject": "Re: Preserve parent",
      "date": "2026-05-15T09:05:00Z"
    },
    {
      "id": "preserve-current",
      "message_id": "<preserve-current@example>",
      "in_reply_to": null,
      "references": [
        "<preserve-unrelated@example>",
        "<preserve-child@example>"
      ],
      "subject": "Re: Preserve parent",
      "date": "2026-05-15T09:10:00Z"
    }
  ],
  "expected": {
    "threads": [
      {
        "root": "preserve-root",
        "messages": [
          "preserve-root",
          "preserve-child",
          "preserve-current"
        ]
      }
    ]
  }
}
