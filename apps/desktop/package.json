{
  "name": "mxr-desktop",
  "private": true,
  "version": "0.4.16",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "sync-version": "node ./scripts/sync-version.mjs",
    "sync-version:check": "node ./scripts/sync-version.mjs --check",
    "sync:tui-manifest": "node ./scripts/sync-tui-manifest.mjs",
    "bundle:mxr": "node ./scripts/stage-bundled-binary.mjs",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "build": "npm run sync:tui-manifest && npm run build:renderer && npm run build:main",
    "typecheck": "npm run sync:tui-manifest && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "npm run sync:tui-manifest && oxlint -c ./.oxlintrc.json --disable-nested-config --react-plugin --vitest-plugin --deny-warnings src",
    "lint:fix": "npm run sync:tui-manifest && oxlint -c ./.oxlintrc.json --disable-nested-config --react-plugin --vitest-plugin --fix src",
    "format": "oxfmt -c ./.oxfmt.json --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "format:check": "oxfmt -c ./.oxfmt.json --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "test": "npm run sync:tui-manifest && vitest run",
    "start": "npm run build && electron dist-electron/main/index.js",
    "package:dir": "npm run sync-version && npm run bundle:mxr && npm run build && electron-forge package",
    "make": "npm run sync-version && npm run bundle:mxr && npm run build && electron-forge make"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.3",
    "jsdom": "^27.2.0",
    "msw": "^2.12.14",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vitest": "^4.0.8"
  }
}
