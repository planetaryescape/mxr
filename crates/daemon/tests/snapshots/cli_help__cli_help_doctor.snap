---
Run diagnostics

Usage: mxr doctor [OPTIONS]

Options:
      --reindex           
      --reindex-semantic  
      --check             
      --semantic-status   
      --verbose           
      --index-stats       
      --store-stats       
      --format <FORMAT>   [possible values: table, json, jsonl, csv, ids]
  -h, --help              Print help
