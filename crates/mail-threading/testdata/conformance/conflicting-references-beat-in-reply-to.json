{
  "name": "conflicting-references-beat-in-reply-to",
  "description": "When References and In-Reply-To conflict, the References chain determines the parent.",
  "spec": {
    "source": "RFC 5256",
    "url": "https://www.rfc-editor.org/rfc/rfc5256",
    "behavior": "References provides the ordered ancestry used for REFERENCES threading"
  },
  "input": [
    {
      "id": "<reference-root@example>",
      "message_id": "<reference-root@example>",
      "in_reply_to": null,
      "references": [],
      "subject": "Reference Root",
      "date": "2026-05-15T09:00:00Z"
    },
    {
      "id": "<irt-other-root@example>",
      "message_id": "<irt-other-root@example>",
      "in_reply_to": null,
      "references": [],
      "subject": "Other Root",
      "date": "2026-05-15T09:01:00Z"
    },
    {
      "id": "<conflict-reply@example>",
      "message_id": "<conflict-reply@example>",
      "in_reply_to": "<irt-other-root@example>",
      "references": [
        "<reference-root@example>"
      ],
      "subject": "Re: Reference Root",
      "date": "2026-05-15T09:05:00Z"
    }
  ],
  "expected": {
    "threads": [
      {
        "root": "<reference-root@example>",
        "messages": [
          "<reference-root@example>",
          "<conflict-reply@example>"
        ]
      },
      {
        "root": "<irt-other-root@example>",
        "messages": [
          "<irt-other-root@example>"
        ]
      }
    ]
  }
}
