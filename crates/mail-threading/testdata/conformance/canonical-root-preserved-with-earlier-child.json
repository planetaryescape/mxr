{
  "name": "canonical-root-preserved-with-earlier-child",
  "description": "The graph root remains canonical even if a child has an earlier date.",
  "spec": {
    "source": "public API contract",
    "url": "https://www.rfc-editor.org/rfc/rfc5256",
    "behavior": "root identity follows the reference graph, not message sort order"
  },
  "input": [
    {
      "id": "<date-root@example>",
      "message_id": "<date-root@example>",
      "in_reply_to": null,
      "references": [],
      "subject": "Date Root",
      "date": "2026-05-15T10:00:00Z"
    },
    {
      "id": "<date-child@example>",
      "message_id": "<date-child@example>",
      "in_reply_to": "<date-root@example>",
      "references": [
        "<date-root@example>"
      ],
      "subject": "Re: Date Root",
      "date": "2026-05-15T09:00:00Z"
    }
  ],
  "expected": {
    "threads": [
      {
        "root": "<date-root@example>",
        "messages": [
          "<date-child@example>",
          "<date-root@example>"
        ]
      }
    ]
  }
}
