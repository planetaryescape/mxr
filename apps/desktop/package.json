{
  "name": "mxr-desktop",
  "private": true,
  "version": "0.4.4",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "sync-version": "node ./scripts/sync-version.mjs",
    "sync-version:check": "node ./scripts/sync-version.mjs --check",
    "bundle:mxr": "node ./scripts/stage-bundled-binary.mjs",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:main",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "start": "npm run build && electron dist-electron/main/index.js",
    "package:dir": "npm run sync-version && npm run bundle:mxr && npm run build && electron-forge package",
    "make": "npm run sync-version && npm run bundle:mxr && npm run build && electron-forge make"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.3",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vitest": "^4.0.8"
  }
}
