  "input": [
    {
      "id": "<irt-missing-reply@example>",
      "message_id": "<irt-missing-reply@example>",
      "in_reply_to": "<irt-missing-root@example>",
      "references": [],
      "subject": "Re: Missing",
      "date": "2026-05-15T09:05:00Z"
    }
  ],
  "expected": {
    "threads": [
      {
        "root": "<irt-missing-reply@example>",
        "messages": [
          "<irt-missing-reply@example>"
        ]
      }
    ]
  }
}
