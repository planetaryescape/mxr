{
  "name": "in-reply-to-only-parent-present",
  "description": "In-Reply-To is used when References is absent and the parent is present.",
  "spec": {
    "source": "RFC 5256",
    "url": "https://www.rfc-editor.org/rfc/rfc5256",
    "behavior": "In-Reply-To can establish parentage when References is absent"
  },
  "input": [
    {
      "id": "<irt-root@example>",
      "message_id": "<irt-root@example>",
      "in_reply_to": null,
      "references": [],
      "subject": "IRT",
      "date": "2026-05-15T09:00:00Z"
    },
    {
      "id": "<irt-reply@example>",
      "message_id": "<irt-reply@example>",
      "in_reply_to": "<irt-root@example>",
      "references": [],
      "subject": "Re: IRT",
      "date": "2026-05-15T09:05:00Z"
    }
  ],
  "expected": {
    "threads": [
      {
        "root": "<irt-root@example>",
        "messages": [
          "<irt-root@example>",
          "<irt-reply@example>"
        ]
      }
    ]
  }
}
