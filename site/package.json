{
  "name": "mxr-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate": "node scripts/generate-cli-reference.mjs && bash scripts/dump-openapi-spec.sh",
    "validate": "node scripts/validate-docs.mjs",
    "postbuild": "node scripts/generate-llms-txt.mjs",
    "dev": "npm run generate && astro dev",
    "build": "npm run generate && npm run validate && astro build && node scripts/generate-llms-txt.mjs",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "0.39.2",
    "@scalar/api-reference": "^1.57.5",
    "astro": "6.3.7",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "@astrojs/sitemap": "3.7.2"
  }
}
