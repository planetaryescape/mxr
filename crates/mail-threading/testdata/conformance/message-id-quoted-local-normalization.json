      "subject": "Quoted",
      "date": "2026-05-15T09:00:00Z"
    },
    {
      "id": "unquoted-reply",
      "message_id": "<quoted-reply@example>",
      "in_reply_to": "<01KF8JCEOCBS0045PS@xxx.yyy.com>",
      "references": [],
      "subject": "Re: Quoted",
      "date": "2026-05-15T09:05:00Z"
    }
  ],
  "expected": {
    "threads": [
      {
        "root": "quoted-root",
        "messages": [
          "quoted-root",
